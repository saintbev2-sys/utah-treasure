<!DOCTYPE html><html><head><meta name='viewport' content='width=device-width,initial-scale=1,user-scalable=no'><title>Soccer</title><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;font-family:Arial;overflow:hidden}#hud{color:#fff;font-size:18px;padding:8px;display:flex;justify-content:space-around;background:#111}canvas{display:block}#btns{display:flex;justify-content:space-between;padding:8px;background:#111;gap:6px}#btns button{flex:1;background:#1a6600;color:#fff;border:2px solid #4cff00;border-radius:10px;padding:14px;font-size:16px;font-weight:bold}</style></head><body><div id=hud><span id=sc>YOU: 0</span><span style=color:#ff0>⚽ SOCCER</span><span id=ai>CPU: 0</span></div><canvas id=c></canvas><div id=btns><button id=bl>◀</button><button id=br>▶</button><button id=bu>▲</button><button id=bk>⚽ KICK</button></div><script>window.onload=function(){var c=document.getElementById('c'),ctx=c.getContext('2d');c.width=window.innerWidth;c.height=window.innerHeight-document.getElementById('hud').offsetHeight-document.getElementById('btns').offsetHeight;var W=c.width,H=c.height;var myScore=0,aiScore=0;var p={x:W/4,y:H/2,w:30,h:40,vx:0,vy:0,ml:false,mr:false,mu:false};var ball={x:W/2,y:H/2,r:12,vx:2,vy:1};var cpu={x:W*3/4,y:H/2,w:30,h:40,spd:2};var GW=60,GH=120;var myGoal={x:0,y:H/2-GH/2,w:GW,h:GH};var aiGoal={x:W-GW,y:H/2-GH/2,w:GW,h:GH};function kick(){var dx=ball.x-(p.x+15);var dy=ball.y-(p.y+20);var dist=Math.sqrt(dx*dx+dy*dy);if(dist<50){ball.vx=dx/dist*10;ball.vy=dy/dist*10;}}document.getElementById('bl').addEventListener('touchstart',function(e){e.preventDefault();p.ml=true;},{passive:false});document.getElementById('bl').addEventListener('touchend',function(e){e.preventDefault();p.ml=false;},{passive:false});document.getElementById('br').addEventListener('touchstart',function(e){e.preventDefault();p.mr=true;},{passive:false});document.getElementById('br').addEventListener('touchend',function(e){e.preventDefault();p.mr=false;},{passive:false});document.getElementById('bu').addEventListener('touchstart',function(e){e.preventDefault();p.mu=true;},{passive:false});document.getElementById('bu').addEventListener('touchend',function(e){e.preventDefault();p.mu=false;},{passive:false});document.getElementById('bk').addEventListener('touchstart',function(e){e.preventDefault();kick();},{passive:false});function resetBall(){ball.x=W/2;ball.y=H/2;ball.vx=Math.random()>0.5?3:-3;ball.vy=Math.random()>0.5?2:-2;}function update(){if(p.ml)p.x-=4;if(p.mr)p.x+=4;if(p.mu)p.y-=4;else p.y+=2;if(p.x<0)p.x=0;if(p.x+p.w>W/2)p.x=W/2-p.w;if(p.y<0)p.y=0;if(p.y+p.h>H)p.y=H-p.h;ball.x+=ball.vx;ball.y+=ball.vy;ball.vy+=0.1;if(ball.y+ball.r>H){ball.y=H-ball.r;ball.vy*=-0.7;}if(ball.y-ball.r<0){ball.y=ball.r;ball.vy*=-0.7;}if(ball.x-ball.r<0){ball.x=ball.r;ball.vx*=-0.9;}if(ball.x+ball.r>W){ball.x=W-ball.r;ball.vx*=-0.9;}ball.vx*=0.99;ball.vy*=0.99;if(ball.x>myGoal.x&&ball.x<myGoal.x+myGoal.w&&ball.y>myGoal.y&&ball.y<myGoal.y+myGoal.h){aiScore++;document.getElementById('ai').textContent='CPU: '+aiScore;resetBall();}if(ball.x>aiGoal.x&&ball.x<aiGoal.x+aiGoal.w&&ball.y>aiGoal.y&&ball.y<aiGoal.y+aiGoal.h){myScore++;document.getElementById('sc').textContent='YOU: '+myScore;resetBall();}var cdx=ball.x-(cpu.x+15);var cdy=ball.y-(cpu.y+20);if(cdx>0)cpu.x+=cpu.spd;else cpu.x-=cpu.spd;if(cdy>0)cpu.y+=cpu.spd;else cpu.y-=cpu.spd;if(cpu.x<W/2)cpu.x=W/2;if(cpu.x+cpu.w>W)cpu.x=W-cpu.w;if(cpu.y<0)cpu.y=0;if(cpu.y+cpu.h>H)cpu.y=H-cpu.h;var cdist=Math.sqrt(cdx*cdx+cdy*cdy);if(cdist<50){ball.vx=-cdx/cdist*8;ball.vy=-cdy/cdist*8;}}function draw(){ctx.fillStyle='#2d8a00';ctx.fillRect(0,0,W,H);ctx.strokeStyle='#fff';ctx.lineWidth=2;ctx.strokeRect(10,10,W-20,H-20);ctx.beginPath();ctx.moveTo(W/2,10);ctx.lineTo(W/2,H-10);ctx.stroke();ctx.beginPath();ctx.arc(W/2,H/2,60,0,Math.PI*2);ctx.stroke();ctx.fillStyle='rgba(255,255,255,0.1)';ctx.fill();ctx.fillStyle='#fff';ctx.fillRect(myGoal.x,myGoal.y,myGoal.w,myGoal.h);ctx.fillRect(aiGoal.x,aiGoal.y,aiGoal.w,aiGoal.h);ctx.fillStyle='#4a90d9';ctx.fillRect(p.x,p.y,p.w,p.h);ctx.fillStyle='#f5c89a';ctx.fillRect(p.x+5,p.y-12,20,18);ctx.fillStyle='#8b0000';ctx.fillRect(cpu.x,cpu.y,cpu.w,cpu.h);ctx.fillStyle='#f5c89a';ctx.fillRect(cpu.x+5,cpu.y-12,20,18);ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(ball.x,ball.y,ball.r,0,Math.PI*2);ctx.fill();ctx.fillStyle='#000';ctx.font='bold 14px Arial';ctx.textAlign='center';ctx.fillText('⚽',ball.x,ball.y+5);}function loop(){update();draw();requestAnimationFrame(loop);}loop();};</script></body></html>
